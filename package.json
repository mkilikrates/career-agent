{
  "name": "career-agent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Local-first browser Career Agent (static bundle, no backend).",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
